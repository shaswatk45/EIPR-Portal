datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String             @id @default(cuid())
  name             String
  email            String             @unique
  password         String
  role             String             @default("user") // "user" or "admin"
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  projects         Project[]
  quizAttempts     QuizAttempt[]
  learningProgress LearningProgress[]
}

model LearningContent {
  id               String             @id @default(cuid())
  title            String
  category         String             // 'patent', 'copyright', 'trademark', 'industrial-design'
  content          String
  examples         String             // Stored as JSON stringified array of strings
  keyPoints        String             // Stored as JSON stringified array of strings
  order            Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  learningProgress LearningProgress[]
}

model LearningProgress {
  id          String          @id @default(cuid())
  userId      String
  contentId   String
  completedAt DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     LearningContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String
  category      String   // 'Software / App', 'Mechanical Device', etc.
  iprSuggestion String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quiz {
  id           String        @id @default(cuid())
  title        String
  category     String        // 'patent', 'copyright', 'trademark', 'industrial-design', 'general'
  description  String        @default("")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  questions    Question[]
  quizAttempts QuizAttempt[]
}

model Question {
  id            String @id @default(cuid())
  quizId        String
  questionText  String
  options       String // Stored as JSON stringified array of strings
  correctAnswer Int    // Index of correct option
  explanation   String @default("")
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  quizId         String
  quizTitle      String?
  score          Int
  totalQuestions Int
  answers        String   // Stored as JSON stringified array of numbers
  attemptedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}
